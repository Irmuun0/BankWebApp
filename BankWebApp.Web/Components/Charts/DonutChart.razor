@using BlazorBootstrap
@implements IAsyncDisposable

<section class="chart-card">
    <div class="chart-card-header">
        <div>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Unit))
        {
            <span class="chart-unit">@Unit</span>
        }
    </div>

    @if (VisibleItems.Count == 0)
    {
        <div class="chart-empty">Харуулах өгөгдөл алга.</div>
    }
    else
    {
        <div class="donut-chart-layout">
            <div class="bb-donut-wrap">
                <BlazorBootstrap.DoughnutChart @ref="doughnutChart" Width="160" Height="160" />
                <div class="donut-chart-center">
                    <strong>@FormatValue(Total)</strong>
                    @if (!string.IsNullOrWhiteSpace(Unit))
                    {
                        <span>@Unit</span>
                    }
                </div>
            </div>

            <div class="donut-chart-legend">
                @foreach (var item in VisibleItems)
                {
                    <div class="donut-chart-legend-item">
                        <span class="donut-chart-swatch" style="@($"background: {item.Color};")"></span>
                        <span class="donut-chart-label">@item.Label</span>
                        <span class="donut-chart-value">@FormatValue(item.Value)</span>
                    </div>
                }
            </div>
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Unit { get; set; }
    [Parameter] public IReadOnlyList<ChartDataPoint> Items { get; set; } = [];

    private BlazorBootstrap.DoughnutChart doughnutChart = default!;
    private ChartData chartData = new();
    private DoughnutChartOptions chartOptions = new();
    private bool chartInitialized;
    private bool pendingChartRefresh = true;

    private IReadOnlyList<ChartDataPoint> VisibleItems => Items.Where(item => item.Value > 0).ToList();
    private decimal Total => VisibleItems.Sum(item => item.Value);

    protected override void OnParametersSet()
    {
        chartData = BuildChartData();
        chartOptions = BuildChartOptions();
        pendingChartRefresh = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (VisibleItems.Count == 0 || !pendingChartRefresh)
        {
            return;
        }

        if (!chartInitialized)
        {
            await doughnutChart.InitializeAsync(chartData, chartOptions);
            chartInitialized = true;
        }
        else
        {
            await doughnutChart.UpdateAsync(chartData, chartOptions);
        }

        pendingChartRefresh = false;
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;

    private ChartData BuildChartData()
    {
        return new ChartData
        {
            Labels = VisibleItems.Select(item => item.Label).ToList(),
            Datasets =
            [
                new DoughnutChartDataset
                {
                    Label = Title,
                    Data = VisibleItems.Select(item => (double?)item.Value).ToList(),
                    BackgroundColor = VisibleItems.Select(item => item.Color).ToList(),
                    BorderColor = VisibleItems.Select(_ => "#ffffff").ToList(),
                    BorderWidth = [4]
                }
            ]
        };
    }

    private static DoughnutChartOptions BuildChartOptions()
    {
        var options = new DoughnutChartOptions();
        options.Responsive = true;
        options.MaintainAspectRatio = false;
        options.Plugins!.Legend.Display = false;
        options.Plugins.Title!.Display = false;
        return options;
    }

    private static string FormatValue(decimal value)
    {
        return value % 1 == 0 ? value.ToString("N0") : value.ToString("N2");
    }
}
