<section class="chart-card">
    <div class="chart-card-header">
        <div>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
    </div>

    @if (VisibleItems.Count == 0)
    {
        <div class="chart-empty">Харуулах өгөгдөл алга.</div>
    }
    else
    {
        <svg class="line-chart" viewBox="0 0 1000 260" role="img" aria-label="@Title" preserveAspectRatio="none">
            <line x1="40" y1="215" x2="980" y2="215" class="line-chart-axis" />
            <line x1="40" y1="25" x2="40" y2="215" class="line-chart-axis" />
            <polyline class="line-chart-line" points="@PolylinePoints" />
            @foreach (var point in ChartPoints)
            {
                <circle cx="@point.X.ToString("0.##")" cy="@point.Y.ToString("0.##")" r="6" class="line-chart-point">
                    <title>@point.Title</title>
                </circle>
            }
        </svg>

        <div class="line-chart-footer">
            <span>@VisibleItems.First().Label</span>
            <strong>@FormatValue(MaxValue)</strong>
            <span>@VisibleItems.Last().Label</span>
        </div>
    }
</section>

@code {
    private const double Left = 40;
    private const double Right = 980;
    private const double Top = 25;
    private const double Bottom = 215;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public string? Unit { get; set; }

    [Parameter]
    public IReadOnlyList<ChartDataPoint> Items { get; set; } = [];

    private IReadOnlyList<ChartDataPoint> VisibleItems => Items
        .Where(item => item.Value >= 0)
        .ToList();

    private decimal MaxValue => VisibleItems.Count == 0 ? 0 : Math.Max(1, VisibleItems.Max(item => item.Value));

    private IReadOnlyList<ChartPoint> ChartPoints => BuildChartPoints();

    private string PolylinePoints => string.Join(" ", ChartPoints.Select(point => $"{point.X:0.##},{point.Y:0.##}"));

    private IReadOnlyList<ChartPoint> BuildChartPoints()
    {
        if (VisibleItems.Count == 0)
        {
            return [];
        }

        var width = Right - Left;
        var height = Bottom - Top;
        var divisor = Math.Max(1, VisibleItems.Count - 1);

        return VisibleItems
            .Select((item, index) =>
            {
                var x = Left + width * index / divisor;
                var y = Bottom - height * (double)(item.Value / MaxValue);
                return new ChartPoint(x, y, $"{item.Label}: {FormatValue(item.Value)}");
            })
            .ToList();
    }

    private string FormatValue(decimal value)
    {
        var formatted = value % 1 == 0 ? value.ToString("N0") : value.ToString("N2");
        return string.IsNullOrWhiteSpace(Unit) ? formatted : $"{formatted} {Unit}";
    }

    private sealed record ChartPoint(double X, double Y, string Title);
}
