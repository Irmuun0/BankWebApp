            <div class="codex-chat-header">
                <div>
                    <div class="codex-kicker">AI review</div>
                    <h2 class="codex-chat-title">Гүйлгээ #@pageModel.ChatTransaction.Id</h2>
                </div>
                <a class="codex-icon-button" href="@CurrentListUrl" aria-label="Хаах">×</a>
            </div>

            <div class="codex-chat-body">
                <section class="codex-context-card">
                    <div class="codex-context-grid">
                        <div>
                            <div class="codex-data-label">Огноо</div>
                            <div class="codex-data-value">@pageModel.ChatTransaction.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>
                        <div>
                            <div class="codex-data-label">Гүйлгээний утга</div>
                            <div class="codex-data-value">@pageModel.ChatTransaction.Description</div>
                        </div>
                        <div>
                            <div class="codex-data-label">Илгээсэн</div>
                            <div class="codex-data-value">@pageModel.ChatTransaction.Amount.ToString("N2") @pageModel.ChatTransaction.SourceCurrency</div>
                        </div>
                        <div>
                            <div class="codex-data-label">Хүлээн авсан</div>
                            <div class="codex-data-value">@pageModel.ChatTransaction.CreditedAmount.ToString("N2") @pageModel.ChatTransaction.TargetCurrency</div>
                        </div>
                    </div>

                    <div class="codex-chip-row">
                        <span class="codex-chip">Rule score @(pageModel.ChatTransaction.RuleRiskScore?.ToString("N2") ?? "-")</span>
                        <span class="codex-chip">AI score @(pageModel.ChatTransaction.LatestAiRiskScore?.ToString("N2") ?? "-")</span>
                    </div>

                    <details class="codex-details">
                        <summary>Гүйлгээний дэлгэрэнгүй</summary>
                        <dl class="row small mt-2 mb-0">
                            <dt class="col-5">Илгээгч</dt>
                            <dd class="col-7">@pageModel.ChatTransaction.FromUserName / @pageModel.ChatTransaction.FromAccountNumber</dd>
                            <dt class="col-5">Хүлээн авагч</dt>
                            <dd class="col-7">@pageModel.ChatTransaction.ToUserName / @pageModel.ChatTransaction.ToAccountNumber</dd>
                            <dt class="col-5">Rule шалтгаан</dt>
                            <dd class="col-7 ai-text-block">@DisplayAiText(pageModel.ChatTransaction.RuleReason)</dd>
                        </dl>
                    </details>
                </section>

                <section class="codex-analysis-card">
                    <div class="codex-section-head">
                        <div>
                            <div class="codex-section-title">AI-ийн шинжилгээний үр дүн</div>
                            <div class="codex-section-meta">
                                @(pageModel.ChatTransaction.LatestAiAnalyzedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Огноо байхгүй")
                            </div>
                        </div>
                        <span class="codex-score">Risk @(pageModel.ChatTransaction.LatestAiRiskScore?.ToString("N2") ?? "00")</span>
                    </div>

                    @if (string.IsNullOrWhiteSpace(pageModel.ChatTransaction.LatestAiExplanation))
                    {
                        <form class="mt-3" method="post" action="/admin/ai-detection/analyze">
                            <input type="hidden" name="TransactionId" value="@pageModel.ChatTransaction.Id" />
                            <input type="hidden" name="ModelName" value="@DefaultAiModel" />
                            <input type="hidden" name="ReturnUrl" value="@BuildChatReturnUrl(pageModel.ChatTransaction.Id)" />
                            <button class="btn btn-dark w-100" type="submit">AI тайлбар авах</button>
                        </form>
                    }
                    else
                    {
                        <div class="codex-analysis-text ai-text-block">@DisplayAiText(pageModel.ChatTransaction.LatestAiExplanation)</div>
                    }
                </section>

                <section class="codex-thread" aria-label="AI chat history">
                    @if (pageModel.ChatMessages.Count == 0)
                    {
                        <div class="codex-empty">Өмнөх chat энд харагдана. Энэ гүйлгээний эрсдэл, rule оноо, хэрэглэгчийн хэв маягийн талаар асууж болно.</div>
                    }
                    else
                    {
                        @foreach (var message in pageModel.ChatMessages)
                        {
                            <article class="codex-message codex-message-user">
                                <div class="codex-message-label">Админ</div>
                                <div class="codex-bubble">@message.Question</div>
                            </article>
                            <article class="codex-message codex-message-ai">
                                <div class="codex-message-label">AI</div>
                                <div class="codex-bubble ai-text-block">@DisplayAiText(message.Answer)</div>
                                <time class="codex-message-time">@message.CreatedAt.ToString("yyyy-MM-dd HH:mm")</time>
                            </article>
                        }
                    }
                </section>
            </div>

            <form class="codex-composer" method="post" action="/admin/ai-detection/chat">
                <input type="hidden" name="TransactionId" value="@pageModel.ChatTransaction.Id" />
                <input type="hidden" name="ReturnUrl" value="@BuildChatReturnUrl(pageModel.ChatTransaction.Id)" />

                <div class="codex-model-row">
                    <label for="modelName">Model</label>
                    <select class="codex-model-select" id="modelName" name="ModelName">
                        <option value="gemini-3.1-flash-lite" label="Gemini 3.1 Flash Lite" selected>Gemini 3.1 Flash Lite</option>
                        <option value="gemini-2.5-flash" label="Gemini 2.5 Flash">Gemini 2.5 Flash        өдөрт 20 асуултын хязгаартай</option>
                        <option value="gemini-3.5-flash" label="Gemini 3.5 Flash">Gemini 3.5 Flash        өдөрт 20 асуултын хязгаартай</option>
                    </select>
                </div>

                <div class="codex-composer-row">
                    <textarea class="codex-composer-input" id="question" name="Question" rows="1" required placeholder="Асуулт оруул"></textarea>
                    <button class="codex-send-button" type="submit" aria-label="Илгээх">
                        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                            <path d="M2 8h10.2M8.5 4.2 12.3 8l-3.8 3.8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>
            </form>
        </aside>
    }
</div>

<script>
    (() => {
        const storageKey = "bank-admin-ai-chat-width";

        function initializeAiChatResize() {
            const panel = document.getElementById("ai-chat-panel");
            if (!panel || panel.dataset.resizeReady === "1") {
                return;
            }

            const handle = panel.querySelector(".codex-panel-resizer");
            const shell = panel.closest(".ai-detection-shell");
            if (!handle || !shell) {
                return;
            }

            panel.dataset.resizeReady = "1";
            const savedWidth = window.localStorage.getItem(storageKey);
            if (savedWidth) {
                panel.style.setProperty("--ai-chat-width", savedWidth);
            }

            handle.addEventListener("pointerdown", event => {
                if (window.innerWidth < 992) {
                    return;
                }

                event.preventDefault();
                handle.setPointerCapture?.(event.pointerId);
                document.body.classList.add("codex-resizing");

                const updateWidth = moveEvent => {
                    const shellRect = shell.getBoundingClientRect();
                    const maxWidth = Math.min(760, shellRect.width * 0.66);
                    const nextWidth = Math.min(Math.max(shellRect.right - moveEvent.clientX, 360), maxWidth);
                    const cssValue = Math.round(nextWidth) + "px";
                    panel.style.setProperty("--ai-chat-width", cssValue);
                    window.localStorage.setItem(storageKey, cssValue);
                };

                const stopResize = () => {
                    document.body.classList.remove("codex-resizing");
                    window.removeEventListener("pointermove", updateWidth);
                    window.removeEventListener("pointerup", stopResize);
                    window.removeEventListener("pointercancel", stopResize);
                };

                window.addEventListener("pointermove", updateWidth);
                window.addEventListener("pointerup", stopResize);
                window.addEventListener("pointercancel", stopResize);
            });
        }

        document.addEventListener("DOMContentLoaded", initializeAiChatResize);
        document.addEventListener("enhancedload", initializeAiChatResize);
        initializeAiChatResize();
    })();
</script>

@code {
    private const string DefaultAiModel = "gemini-3.1-flash-lite";
    private AdminAiDetectionPageDto pageModel = new();
    private bool isLoading = true;

    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    [SupplyParameterFromQuery]
    public string? Username { get; set; }

    [SupplyParameterFromQuery]
    public string? Currency { get; set; }

    [SupplyParameterFromQuery]
    public decimal? MinRiskScore { get; set; }

    [SupplyParameterFromQuery]
    public DateOnly? StartDate { get; set; }

    [SupplyParameterFromQuery]
    public DateOnly? EndDate { get; set; }

    [SupplyParameterFromQuery]
    public long? ChatTransactionId { get; set; }

    [SupplyParameterFromQuery]
    public int Page { get; set; } = 1;

    [SupplyParameterFromQuery]
    public int PageSize { get; set; } = 50;

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string CurrentListUrl => BuildPageHref(Page, includeChat: false);

    protected override async Task OnParametersSetAsync()
    {
        pageModel = await AdminService.GetAiDetectionPageAsync(
            Search,
            Username,
            Currency,
            MinRiskScore,
            StartDate,
            EndDate,
            ChatTransactionId,
            Page,
            PageSize);

        isLoading = false;
    }

    private string BuildPresetHref(string preset)
    {
        var today = MongoliaClock.Today;
        return preset switch
        {
            "yesterday" => $"/admin/ai-detection?startDate={today.AddDays(-1):yyyy-MM-dd}&endDate={today.AddDays(-1):yyyy-MM-dd}&pageSize={NormalizedPageSize}",
            "last7" => $"/admin/ai-detection?startDate={today.AddDays(-6):yyyy-MM-dd}&endDate={today:yyyy-MM-dd}&pageSize={NormalizedPageSize}",
            "highRisk" => $"/admin/ai-detection?minRiskScore=60&pageSize={NormalizedPageSize}",
            _ => "/admin/ai-detection"
        };
    }

    private string BuildChatHref(long transactionId)
    {
        return BuildChatReturnUrl(transactionId);
    }

    private string BuildChatReturnUrl(long transactionId)
    {
        return $"{BuildPageHref(Page, includeChat: false)}&chatTransactionId={transactionId}";
    }

    private string BuildPageHref(int page, bool includeChat = true)
    {
        var query = new List<string>
        {
            $"page={Math.Max(1, page)}",
            $"pageSize={NormalizedPageSize}"
        };

        AddQuery(query, "search", Search);
        AddQuery(query, "username", Username);
        AddQuery(query, "currency", Currency);
        AddQuery(query, "minRiskScore", MinRiskScore?.ToString());
        AddQuery(query, "startDate", StartDate?.ToString("yyyy-MM-dd"));
        AddQuery(query, "endDate", EndDate?.ToString("yyyy-MM-dd"));

        if (includeChat && ChatTransactionId is not null)
        {
            AddQuery(query, "chatTransactionId", ChatTransactionId.Value.ToString());
        }

        return $"/admin/ai-detection?{string.Join("&", query)}";
    }

    private int NormalizedPageSize => PageSize == 100 ? 100 : 50;

    private static void AddQuery(List<string> query, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            query.Add($"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}");
        }
    }

    private static string DisplayAiText(string? value)
    {
        return value ?? string.Empty;
    }
}
