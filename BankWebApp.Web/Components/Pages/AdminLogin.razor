@page "/admin/login"
@attribute [AllowAnonymous]

<PageTitle>Admin нэвтрэх</PageTitle>

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
        <h1 class="mb-4">Admin нэвтрэх</h1>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }

        <form method="post" action="/auth/login">
            <input type="hidden" name="ReturnUrl" value="@ReturnUrlOrAdminDashboard" />
            <input type="hidden" name="RequiredRole" value="ADMIN" />
            <input type="hidden" name="LoginPath" value="/admin/login" />

            <div class="mb-3">
                <label class="form-label" for="adminUsernameOrEmail">Admin нэр эсвэл имэйл</label>
                <input class="form-control" id="adminUsernameOrEmail" name="UsernameOrEmail" autocomplete="username" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="adminPassword">Нууц үг</label>
                <div class="input-group">
                    <input class="form-control" id="adminPassword" name="Password" type="password" autocomplete="current-password" />
                    <button class="btn btn-outline-secondary" type="button" aria-label="Нууц үг харах" onclick="togglePasswordVisibility('adminPassword')">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
            </div>

            <button class="btn btn-primary w-100" type="submit">Admin нэвтрэх</button>
        </form>

        <div class="mt-3">
            <a href="/">Хэрэглэгчээр нэвтрэх</a>
        </div>
    </div>
</div>

<script>
    function togglePasswordVisibility(inputId) {
        const input = document.getElementById(inputId);
        if (!input) return;
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string ReturnUrlOrAdminDashboard => string.IsNullOrWhiteSpace(ReturnUrl) ? "/admin/dashboard" : ReturnUrl;
}
