@page "/admin/users"
@attribute [Authorize(Roles = "ADMIN")]
@inject IAdminService AdminService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Navigation

<PageTitle>Админ - Хэрэглэгчид</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Хэрэглэгчид</h1>
</div>

@if (!string.IsNullOrWhiteSpace(Success))
{
    <div class="alert alert-success" role="alert">@Success</div>
}

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger" role="alert">@Error</div>
}

@if (isLoading)
{
    <p><em>Уншиж байна...</em></p>
}
else
{
    <form class="row g-2 mb-3" method="get" action="/admin/users">
        <div class="col-12 col-md-5">
            <input class="form-control" name="search" value="@Search" placeholder="Username, email, нэр, утас хайх" />
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-primary" type="submit">Хайх</button>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary" href="/admin/users">Цэвэрлэх</a>
        </div>
    </form>
}

@if (!isLoading && users.Items.Count == 0)
{
    <p>Хэрэглэгч олдсонгүй.</p>
}
else if (!isLoading)
{
    <table class="table table-striped align-middle" data-client-sort="true">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Нэр, овог</th>
                <th>Утас</th>
                <th>Role</th>
                <th>Төлөв</th>
                <th>Бүртгэсэн огноо</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users.Items)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@(user.FullName ?? "-")</td>
                    <td>@(user.PhoneNumber ?? "-")</td>
                    <td>@user.Role</td>
                    <td>@DisplayActive(user.IsActive)</td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <form method="post" action="/admin/users/toggle-status">
                            <input type="hidden" name="UserId" value="@user.Id" />
                            <input type="hidden" name="IsActive" value="@(!user.IsActive)" />
                            <input type="hidden" name="ReturnUrl" value="@CurrentPageUrl" />
                            <button class="btn p-0 border-0 bg-transparent"
                                    type="submit"
                                    title="Төлөв солих"
                                    disabled="@(CurrentUser.UserId == user.Id && user.IsActive)">
                                <span class="d-inline-flex align-items-center rounded-pill p-1 @(user.IsActive ? "bg-success" : "bg-secondary")" style="width: 44px;">
                                    <span class="bg-white rounded-circle d-inline-block @(user.IsActive ? "ms-auto" : "")" style="width: 18px; height: 18px;"></span>
                                </span>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <AdminPager BasePath="/admin/users" Page="@users.Page" TotalPages="@users.TotalPages" Search="@Search" />
}

@code {
    private AdminPagedResultDto<AdminUserDto> users = new();
    private bool isLoading = true;

    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    [SupplyParameterFromQuery]
    public int Page { get; set; } = 1;

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        users = await AdminService.GetUsersAsync(Search, Page);
        isLoading = false;
    }

    private string CurrentPageUrl => "/" + Navigation.ToBaseRelativePath(Navigation.Uri);

    private static string DisplayActive(bool isActive)
    {
        return isActive ? "Идэвхтэй" : "Идэвхгүй";
    }
}
