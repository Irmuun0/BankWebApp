@page "/admin/suspicious-transactions/{TransactionId:long}"
@attribute [Authorize(Roles = "ADMIN")]
@inject IAdminService AdminService

<PageTitle>Админ - Сэжигтэй гүйлгээний дэлгэрэнгүй</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Сэжигтэй гүйлгээний дэлгэрэнгүй</h1>
    <a class="btn btn-outline-secondary" href="/admin/suspicious-transactions">Буцах</a>
</div>

@if (!string.IsNullOrWhiteSpace(Success))
{
    <div class="alert alert-success" role="alert">@Success</div>
}

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger" role="alert">@Error</div>
}

@if (isLoading)
{
    <p><em>Уншиж байна...</em></p>
}
else if (detail is null)
{
    <div class="alert alert-warning" role="alert">Сэжигтэй гүйлгээ олдсонгүй.</div>
}
else
{
    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Гүйлгээ</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Гүйлгээний ID</dt>
                    <dd class="col-sm-7">@detail.TransactionId</dd>
                    <dt class="col-sm-5">Огноо</dt>
                    <dd class="col-sm-7">@detail.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    <dt class="col-sm-5">Илгээгч</dt>
                    <dd class="col-sm-7">@detail.FromAccountNumber</dd>
                    <dt class="col-sm-5">Хүлээн авагч</dt>
                    <dd class="col-sm-7">@detail.ToAccountNumber</dd>
                    <dt class="col-sm-5">Гүйлгээний дүн</dt>
                    <dd class="col-sm-7">@detail.Amount.ToString("N2") @detail.SourceCurrency</dd>
                    <dt class="col-sm-5">Хүлээн авсан дүн</dt>
                    <dd class="col-sm-7">@detail.CreditedAmount.ToString("N2") @detail.TargetCurrency</dd>
                    <dt class="col-sm-5">Risk score</dt>
                    <dd class="col-sm-7">@detail.RiskScore.ToString("N2")</dd>
                    <dt class="col-sm-5">Review төлөв</dt>
                    <dd class="col-sm-7">@detail.ReviewStatusLabel</dd>
                    <dt class="col-sm-5">Review хийсэн</dt>
                    <dd class="col-sm-7">@(detail.ReviewedByUsername ?? "-")</dd>
                    <dt class="col-sm-5">Review огноо</dt>
                    <dd class="col-sm-7">@(detail.ReviewedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Шалтгаан ба AI тайлбар</h2>
                <div class="mb-3">
                    <div class="fw-semibold">Сэжигтэй шалтгаан</div>
                    <p>@detail.SuspiciousReason</p>
                </div>
                <div>
                    <div class="fw-semibold">AI тайлбар</div>
                    <p>@detail.AiExplanation</p>
                </div>
            </div>
        </div>
    </div>

    <form class="border rounded p-3 mt-4" method="post" action="/admin/suspicious-transactions/review">
        <input type="hidden" name="TransactionId" value="@detail.TransactionId" />
        <input type="hidden" name="ExpectedUpdatedAtTicks" value="@detail.UpdatedAt.Ticks" />
        <input type="hidden" name="ReturnUrl" value="@($"/admin/suspicious-transactions/{detail.TransactionId}")" />

        <h2 class="h5">Review шинэчлэх</h2>

        <div class="mb-3">
            <label class="form-label" for="reviewStatus">Review төлөв</label>
            <select class="form-select" id="reviewStatus" name="ReviewStatus">
                @foreach (var status in ReviewStatusHelper.AllowedStatuses)
                {
                    <option value="@status" selected="@(detail.ReviewStatus == status)">@ReviewStatusHelper.GetLabel(status)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label" for="reviewNote">Review тэмдэглэл</label>
            <textarea class="form-control" id="reviewNote" name="ReviewNote" rows="4">@detail.ReviewNote</textarea>
        </div>

        <div class="border rounded p-3 mb-3 bg-light">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="sendUserNotification" name="SendUserNotification" value="true" />
                <label class="form-check-label fw-semibold" for="sendUserNotification">Хэрэглэгчид мэдэгдэл илгээх</label>
            </div>
            <label class="form-label small text-muted" for="userNotificationMessage">Мэдэгдлийн текст</label>
            <textarea class="form-control" id="userNotificationMessage" name="UserNotificationMessage" rows="3"
                      placeholder="Хоосон үлдээвэл review төлөвт тохирсон стандарт мэдэгдэл илгээгдэнэ."></textarea>
        </div>
        <button class="btn btn-primary" type="submit">Хадгалах</button>
    </form>
}

@code {
    [Parameter]
    public long TransactionId { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private AdminSuspiciousTransactionDto? detail;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        detail = await AdminService.GetSuspiciousTransactionDetailAsync(TransactionId);
        isLoading = false;
    }
}
