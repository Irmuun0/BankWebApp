@page "/accounts/{Id:long}"
@attribute [Authorize(Roles = "USER,ADMIN")]
@inject ICurrentUserService CurrentUser
@inject IAccountService AccountService

<PageTitle>Дансны дэлгэрэнгүй</PageTitle>

<h1>Дансны дэлгэрэнгүй</h1>

@if (isLoading)
{
    <p><em>Уншиж байна...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning" role="alert">@errorMessage</div>
    <a class="btn btn-outline-primary" href="/accounts">Миний дансууд</a>
}
else if (account is not null)
{
    @if (!string.IsNullOrWhiteSpace(Success))
    {
        <div class="alert alert-success" role="alert">@Success</div>
    }
    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="alert alert-warning" role="alert">@Error</div>
    }

    <div class="border rounded p-4" style="max-width: 720px;">
        <div class="mb-3">
            <div class="text-muted">Дансны дугаар</div>
            <div class="d-flex align-items-center gap-2">
                <span class="fs-5 fw-semibold">@account.AccountNumber</span>
                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        title="Дансны дугаар хуулах"
                        onclick="navigator.clipboard.writeText('@account.AccountNumber')">
                    <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="currentColor" d="M16 1H4a2 2 0 0 0-2 2v12h2V3h12V1Zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H8V7h11v14Z" />
                    </svg>
                </button>
            </div>
        </div>

        <dl class="row mb-0">
            <dt class="col-sm-4">Дансны нэр</dt>
            <dd class="col-sm-8">@AccountName</dd>

            <dt class="col-sm-4">Төрөл</dt>
            <dd class="col-sm-8">@DisplayAccountType(account.AccountType)</dd>

            <dt class="col-sm-4">Нийт үлдэгдэл</dt>
            <dd class="col-sm-8">@account.Balance.ToString("N2")@account.Currency</dd>

            <dt class="col-sm-4">Төлөв</dt>
            <dd class="col-sm-8">@(account.IsActive ? "Идэвхтэй" : "Идэвхгүй")</dd>

            <dt class="col-sm-4">Нээсэн огноо</dt>
            <dd class="col-sm-8">@account.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-4">Сүүлд хийсэн гүйлгээний огноо</dt>
            <dd class="col-sm-8">@LastTransactionDate</dd>

            <dt class="col-sm-4">Үндсэн эзэмшигч</dt>
            <dd class="col-sm-8">@OwnerName</dd>
        </dl>

        <form class="border-top pt-3 mt-3" method="post" action="/accounts/set-primary">
            <input type="hidden" name="AccountId" value="@account.Id" />
            <input type="hidden" name="ReturnUrl" value="@($"/accounts/{account.Id}")" />
            <div class="form-check mb-2">
                <input class="form-check-input" id="isPrimaryAccount" type="checkbox" checked="@account.IsPrimary" disabled />
                <label class="form-check-label" for="isPrimaryAccount">Үндсэн данс</label>
            </div>
            @if (!account.IsPrimary)
            {
                <button class="btn btn-outline-primary" type="submit" disabled="@(!account.IsActive)">Үндсэн данс болгох</button>
            }
        </form>
    </div>

    <div class="mt-3">
        <a class="btn btn-outline-primary" href="/accounts">Буцах</a>
    </div>
}

@code {
    [Parameter]
    public long Id { get; set; }

    [SupplyParameterFromQuery(Name = "success")]
    public string? Success { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private BankWebApp.Web.DTOs.Accounts.AccountDto? account;
    private bool isLoading = true;
    private string? errorMessage;

    private string AccountName => account is null
        ? string.Empty
        : $"{DisplayAccountType(account.AccountType).ToUpperInvariant()}/{account.Currency}";

    private string LastTransactionDate => account?.LastTransactionAt?.ToString("yyyy-MM-dd") ?? "-";

    private string OwnerName => string.IsNullOrWhiteSpace(account?.OwnerName) ? "-" : account.OwnerName;

    protected override async Task OnParametersSetAsync()
    {
        var userId = CurrentUser.UserId;
        if (userId is null)
        {
            errorMessage = "Та нэвтрээгүй байна.";
            isLoading = false;
            return;
        }

        account = await AccountService.GetMyAccountByIdAsync(userId.Value, Id);
        if (account is null)
        {
            errorMessage = "Данс олдсонгүй эсвэл та энэ дансыг харах эрхгүй байна.";
        }

        isLoading = false;
    }

    private static string DisplayAccountType(string accountType)
    {
        return accountType == "CHECKING" ? "Харилцах" : accountType;
    }
}
