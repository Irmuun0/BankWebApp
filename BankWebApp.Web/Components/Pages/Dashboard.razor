@page "/dashboard"
@attribute [Authorize(Roles = "USER,ADMIN")]
@rendermode InteractiveServer
@inject ICurrentUserService CurrentUser
@inject IAccountService AccountService
@inject ITransactionService TransactionService

<PageTitle>Хэрэглэгчийн самбар</PageTitle>

@if (isLoading)
{
    <p><em>Уншиж байна...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning" role="alert">@errorMessage</div>
}
else
{
    <p class="dashboard-greeting">Сайн байна уу, @DisplayName.</p>

    @if (selectedAccount is not null)
    {
        <form class="dashboard-account-picker mb-4" method="get" action="/dashboard">
            <div class="dashboard-account-picker-grid">
                <div class="dashboard-account-field">
                    <label class="form-label" for="accountId">Харах данс</label>
                    <div class="dashboard-select-shell">
                        <select class="form-select dashboard-account-select" id="accountId" name="accountId">
                        @foreach (var account in allAccounts)
                        {
                            <option value="@account.Id" selected="@(account.Id == selectedAccount.Id)">
                                @account.AccountNumber - @DisplayAccountType(account.AccountType)/@account.Currency (@FormatMoney(account.Balance))
                            </option>
                        }
                        </select>
                    </div>
                </div>
                <div class="dashboard-account-action">
                    <button class="dashboard-select-button" type="submit">Сонгох</button>
                </div>
            </div>
        </form>
    }

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted">Нийт данс</div>
                <div class="fs-4">@summary.TotalAccounts</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted">Идэвхтэй данс</div>
                <div class="fs-4">@summary.ActiveAccountCount</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted">MNT үлдэгдэл</div>
                <div class="fs-4">@FormatMoney(summary.TotalMntBalance) MNT</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="border rounded p-3">
                <div class="text-muted">USD үлдэгдэл</div>
                <div class="fs-4">@FormatMoney(summary.TotalUsdBalance) USD</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-xl-8">
            <BarChart Title="Дансны үлдэгдэл"
                      Subtitle="Валют бүрээр нэгтгэсэн үлдэгдэл"
                      Items="@BalanceByCurrencyChart" />
        </div>
        <div class="col-12 col-xl-4">
            <IncomeExpenseDonutChart Title="Орлого / зарлага"
                                     Subtitle="Сүүлийн 1 сарын сонгосон дансны мөнгөн урсгал"
                                     Income="@MonthlyIncome"
                                     Expense="@MonthlyExpense"
                                     Currency="@(selectedAccount?.Currency ?? string.Empty)" />
        </div>
        <div class="col-12">
            <LineChart Title="Сүүлийн 7 өдрийн гүйлгээ"
                       Subtitle="Сонгосон дансны өдөр бүрийн гүйлгээний тоо"
                       Unit="ш"
                       Items="@RecentTransactionTrendChart" />
        </div>
    </div>

    <h2 class="h5">Миний данснууд</h2>
    @if (allAccounts.Count == 0)
    {
        <p>Танд одоогоор данс байхгүй байна.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Дансны дугаар</th>
                    <th>Валют</th>
                    <th>Үлдэгдэл</th>
                    <th>Төлөв</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var account in allAccounts)
                {
                    <tr>
                        <td>
                            @if (account.IsPrimary)
                            {
                                <span class="badge text-bg-primary me-1" title="Үндсэн данс">★</span>
                            }
                            @account.AccountNumber
                        </td>
                        <td>@account.Currency</td>
                        <td>@FormatMoney(account.Balance)</td>
                        <td>@(account.IsActive ? "Идэвхтэй" : "Идэвхгүй")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Сүүлийн гүйлгээнүүд</h2>
    @if (selectedAccount is not null)
    {
        <p class="text-muted mb-2">@selectedAccount.AccountNumber дансны сүүлийн гүйлгээнүүд</p>
    }

    @if (recentTransactions.Count == 0)
    {
        <p>Сонгосон дансанд одоогоор гүйлгээ байхгүй байна.</p>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Огноо</th>
                    <th>Чиглэл</th>
                    <th>Дүн</th>
                    <th>Орсон дүн</th>
                    <th>Төлөв</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in recentTransactions)
                {
                    <tr role="button" onclick="window.location.href='@BuildDashboardTransactionDetailHref(transaction.Id)'">
                        <td>@transaction.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@DisplayDirection(transaction.Direction)</td>
                        <td>@transaction.Amount.ToString("N2") @transaction.SourceCurrency</td>
                        <td>@transaction.CreditedAmount.ToString("N2") @transaction.TargetCurrency</td>
                        <td>@DisplayStatus(transaction.Status)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<TransactionDetailModal Receipt="@selectedReceipt" CloseHref="@BuildDashboardCloseHref()" />

@code {
    [SupplyParameterFromQuery(Name = "accountId")]
    public long? AccountId { get; set; }

    [SupplyParameterFromQuery(Name = "detail")]
    public long? DetailTransactionId { get; set; }

    private BankWebApp.Web.DTOs.Accounts.AccountSummaryDto summary = new();
    private List<BankWebApp.Web.DTOs.Accounts.AccountDto> allAccounts = [];
    private List<BankWebApp.Web.DTOs.Transactions.UserTransactionDto> recentTransactions = [];
    private List<BankWebApp.Web.DTOs.Transactions.UserTransactionDto> monthlyTransactions = [];
    private BankWebApp.Web.DTOs.Accounts.AccountDto? selectedAccount;
    private BankWebApp.Web.DTOs.Transactions.TransactionReceiptDto? selectedReceipt;
    private bool isLoading = true;
    private string? errorMessage;

    private string DisplayName => CurrentUser.FullName ?? CurrentUser.Username ?? "хэрэглэгч";

    protected override async Task OnParametersSetAsync()
    {
        var userId = CurrentUser.UserId;
        if (userId is null)
        {
            errorMessage = "Та нэвтрээгүй байна.";
            isLoading = false;
            return;
        }

        summary = await AccountService.GetMyAccountSummaryAsync(userId.Value);
        allAccounts = await AccountService.GetMyAccountsAsync(userId.Value);
        selectedAccount = ResolveSelectedAccount();
        recentTransactions = [];
        monthlyTransactions = [];

        if (selectedAccount is not null)
        {
            recentTransactions = await TransactionService.GetRecentMyTransactionsAsync(userId.Value, selectedAccount.Id);
            var today = MongoliaClock.Today;
            monthlyTransactions = await TransactionService.GetMyTransactionsAsync(
                userId.Value,
                selectedAccount.Id,
                today.AddMonths(-1),
                today);
        }

        if (DetailTransactionId is not null)
        {
            selectedReceipt = await TransactionService.GetMyTransactionReceiptAsync(userId.Value, DetailTransactionId.Value);
        }

        isLoading = false;
    }

    private BankWebApp.Web.DTOs.Accounts.AccountDto? ResolveSelectedAccount()
    {
        if (AccountId is not null)
        {
            var requested = allAccounts.FirstOrDefault(account => account.Id == AccountId.Value);
            if (requested is not null)
            {
                return requested;
            }
        }

        return allAccounts.FirstOrDefault(account => account.IsPrimary)
            ?? allAccounts.FirstOrDefault(account => account.IsActive)
            ?? allAccounts.FirstOrDefault();
    }

    private static string FormatMoney(decimal value)
    {
        return value.ToString("N2");
    }

    private static string DisplayDirection(string direction)
    {
        return direction == "SENT" ? "Илгээсэн" : "Хүлээн авсан";
    }

    private static string DisplayStatus(string status)
    {
        return status == "SUCCESS" ? "Амжилттай" : status;
    }

    private static string DisplayAccountType(string accountType)
    {
        return accountType == "CHECKING" ? "Харилцах" : accountType;
    }

    private string BuildDashboardTransactionDetailHref(long transactionId)
    {
        var accountQuery = selectedAccount is null ? string.Empty : $"accountId={selectedAccount.Id}&";
        return $"/dashboard?{accountQuery}detail={transactionId}";
    }

    private string BuildDashboardCloseHref()
    {
        return selectedAccount is null ? "/dashboard" : $"/dashboard?accountId={selectedAccount.Id}";
    }

    private IReadOnlyList<ChartDataPoint> BalanceByCurrencyChart => allAccounts
        .GroupBy(account => account.Currency)
        .OrderBy(group => group.Key)
        .Select((group, index) => new ChartDataPoint
        {
            Label = group.Key,
            Value = group.Sum(account => account.Balance),
            Color = ChartColors[index % ChartColors.Length]
        })
        .ToList();

    private decimal MonthlyIncome => monthlyTransactions
        .Where(transaction => transaction.Direction != "SENT")
        .Sum(transaction => transaction.CreditedAmount);

    private decimal MonthlyExpense => monthlyTransactions
        .Where(transaction => transaction.Direction == "SENT")
        .Sum(transaction => transaction.Amount);

    private IReadOnlyList<ChartDataPoint> RecentTransactionTrendChart
    {
        get
        {
            var today = MongoliaClock.Today;
            return Enumerable.Range(0, 7)
                .Select(offset => today.AddDays(offset - 6))
                .Select(day => new ChartDataPoint
                {
                    Label = day.ToString("MM-dd"),
                    Value = recentTransactions.Count(transaction => DateOnly.FromDateTime(transaction.CreatedAt) == day),
                    Color = "#2563eb"
                })
                .ToList();
        }
    }

    private static readonly string[] ChartColors =
    [
        "#2563eb",
        "#16a34a",
        "#f59e0b",
        "#7c3aed",
        "#0891b2",
        "#dc2626"
    ];
}
