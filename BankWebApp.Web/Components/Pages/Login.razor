@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Нэвтрэх</PageTitle>

<div class="min-vh-100 d-flex flex-column align-items-center justify-content-center position-relative px-3 py-5">
    <div class="border rounded p-4" style="width: 100%; max-width: 420px;">
        <h1 class="h3 mb-4 text-center">Хэрэглэгч нэвтрэх</h1>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }

        <form method="post" action="/auth/login">
            <input type="hidden" name="ReturnUrl" value="@ReturnUrlOrDashboard" />
            <input type="hidden" name="RequiredRole" value="USER" />
            <input type="hidden" name="LoginPath" value="/" />

            <div class="mb-3">
                <label class="form-label" for="usernameOrEmail">Хэрэглэгчийн нэр эсвэл имэйл</label>
                <input class="form-control" id="usernameOrEmail" name="UsernameOrEmail" autocomplete="username" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="password">Нууц үг Password@123</label>
                <div class="input-group">
                    <input class="form-control" id="password" name="Password" type="password" autocomplete="current-password" />
                    <button class="btn btn-outline-secondary" type="button" aria-label="Нууц үг харах" onclick="togglePasswordVisibility('password')">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
            </div>

            <button class="btn btn-primary w-100" type="submit">Нэвтрэх</button>
        </form>
    </div>

    <MongolBankRateCards />

    <a class="btn btn-outline-secondary position-absolute bottom-0 start-0 m-4" href="/admin/login">Admin нэвтрэх</a>
</div>

<script>
    function togglePasswordVisibility(inputId) {
        const input = document.getElementById(inputId);
        if (!input) return;
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string ReturnUrlOrDashboard => string.IsNullOrWhiteSpace(ReturnUrl) ? "/dashboard" : ReturnUrl;
}
