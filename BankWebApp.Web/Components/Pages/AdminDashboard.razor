@page "/admin/dashboard"
@attribute [Authorize(Roles = "ADMIN")]
@inject ICurrentUserService CurrentUser
@inject IAdminService AdminService

<PageTitle>Админ самбар</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Админ самбар</h1>
</div>

<p>Сайн байна уу, @DisplayName.</p>

@if (isLoading)
{
    <p><em>Уншиж байна...</em></p>
}
else
{
    <div class="row g-3 mb-4">
        <SummaryCard Title="Нийт хэрэглэгч" Value="@summary.TotalUsers.ToString("N0")" />
        <SummaryCard Title="Идэвхтэй хэрэглэгч" Value="@summary.ActiveUsers.ToString("N0")" />
        <SummaryCard Title="Идэвхгүй хэрэглэгч" Value="@summary.InactiveUsers.ToString("N0")" />
        <SummaryCard Title="Нийт данс" Value="@summary.TotalAccounts.ToString("N0")" />
        <SummaryCard Title="Идэвхтэй данс" Value="@summary.ActiveAccounts.ToString("N0")" />
        <SummaryCard Title="Нийт гүйлгээ" Value="@summary.TotalTransactions.ToString("N0")" />
        <SummaryCard Title="Сэжигтэй гүйлгээ" Value="@summary.SuspiciousTransactions.ToString("N0")" />
        <SummaryCard Title="Хүлээгдэж буй review" Value="@summary.PendingReviews.ToString("N0")" />
        <SummaryCard Title="Өнөөдрийн гүйлгээ" Value="@summary.TodayTransactions.ToString("N0")" />
        <SummaryCard Title="Өнөөдрийн сэжигтэй" Value="@summary.TodaySuspiciousTransactions.ToString("N0")" />
        <SummaryCard Title="Өнөөдрийн FX орлого" Value="@($"{summary.TodayFxIncomeMnt:N2} MNT")" />
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <DonutChart Title="Хэрэглэгчийн төлөв"
                        Subtitle="Идэвхтэй ба идэвхгүй хэрэглэгч"
                        Unit="хүн"
                        Items="@UserStatusChart" />
        </div>
        <div class="col-12 col-lg-4">
            <DonutChart Title="Дансны төлөв"
                        Subtitle="Идэвхтэй ба идэвхгүй данс"
                        Unit="данс"
                        Items="@AccountStatusChart" />
        </div>
        <div class="col-12 col-lg-4">
            <BarChart Title="Эрсдэлийн үзүүлэлт"
                      Subtitle="Сэжигтэй гүйлгээ болон review хүлээгдэж буй тоо"
                      Unit="ш"
                      Items="@RiskChart" />
        </div>
        <div class="col-12 col-lg-6">
            <BarChart Title="Өнөөдрийн идэвх"
                      Subtitle="Өнөөдрийн нийт болон сэжигтэй гүйлгээ"
                      Unit="ш"
                      Items="@TodayActivityChart" />
        </div>
        <div class="col-12 col-lg-6">
            <BarChart Title="Системийн хэмжээ"
                      Subtitle="Нийт хэрэглэгч, данс, гүйлгээ"
                      Unit="ш"
                      Items="@SystemScaleChart" />
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" href="/admin/users">Хэрэглэгчид</a>
        <a class="btn btn-outline-primary" href="/admin/accounts">Данснууд</a>
        <a class="btn btn-outline-primary" href="/admin/transactions">Бүх гүйлгээ</a>
        <a class="btn btn-outline-primary" href="/admin/exchange-rates">Ханш тохируулах</a>
        <a class="btn btn-outline-primary" href="/admin/fx-income">FX орлогын тайлан</a>
        <a class="btn btn-outline-danger" href="/admin/suspicious-transactions">Сэжигтэй гүйлгээ</a>
        <a class="btn btn-outline-dark" href="/admin/audit-logs">Audit log</a>
    </div>
}

@code {
    private AdminDashboardSummaryDto summary = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        summary = await AdminService.GetDashboardSummaryAsync();
        isLoading = false;
    }

    private string DisplayName => CurrentUser.FullName ?? CurrentUser.Username ?? "админ";

    private IReadOnlyList<ChartDataPoint> UserStatusChart =>
    [
        new() { Label = "Идэвхтэй", Value = summary.ActiveUsers, Color = "#16a34a" },
        new() { Label = "Идэвхгүй", Value = summary.InactiveUsers, Color = "#94a3b8" }
    ];

    private IReadOnlyList<ChartDataPoint> AccountStatusChart =>
    [
        new() { Label = "Идэвхтэй", Value = summary.ActiveAccounts, Color = "#2563eb" },
        new() { Label = "Идэвхгүй", Value = Math.Max(0, summary.TotalAccounts - summary.ActiveAccounts), Color = "#94a3b8" }
    ];

    private IReadOnlyList<ChartDataPoint> RiskChart =>
    [
        new() { Label = "Сэжигтэй", Value = summary.SuspiciousTransactions, Color = "#dc2626" },
        new() { Label = "Review", Value = summary.PendingReviews, Color = "#f59e0b" }
    ];

    private IReadOnlyList<ChartDataPoint> TodayActivityChart =>
    [
        new() { Label = "Өнөөдрийн гүйлгээ", Value = summary.TodayTransactions, Color = "#2563eb" },
        new() { Label = "Өнөөдрийн сэжигтэй", Value = summary.TodaySuspiciousTransactions, Color = "#dc2626" }
    ];

    private IReadOnlyList<ChartDataPoint> SystemScaleChart =>
    [
        new() { Label = "Хэрэглэгч", Value = summary.TotalUsers, Color = "#16a34a" },
        new() { Label = "Данс", Value = summary.TotalAccounts, Color = "#2563eb" },
        new() { Label = "Гүйлгээ", Value = summary.TotalTransactions, Color = "#7c3aed" }
    ];
}
